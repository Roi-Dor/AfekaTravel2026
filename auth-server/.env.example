# Server Configuration
PORT=5001
NODE_ENV=development

# MongoDB Connection
# Local: mongodb://localhost:27017/travel-afeka
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/travel-afeka?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/travel-afeka

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Developers Names (included in JWT)
DEVELOPERS=Roi,Developer2

# Client URL (for CORS) — set to your Vercel URL in production
CLIENT_URL=http://localhost:3000
